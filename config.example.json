{
  "_comment": "Telegram Gateway config. Copy to config.json and fill in your values.",
  "_note": "Agent names (jarvis, homer, edith) are EXAMPLES. Replace with your own.",
  "poll_interval_sec": 2,
  "allowlist_user_ids": [123456789],
  "webhook_port": 0,
  "webhook_token": "",
  "agents": {
    "jarvis": {
      "_role": "coordinator -- routes tasks, manages agents",
      "enabled": true,
      "telegram_bot_token": "YOUR_JARVIS_BOT_TOKEN",
      "workspace": "/home/user/.claude-lab/jarvis/.claude",
      "model": "opus",
      "timeout_sec": 120,
      "streaming_mode": "partial",
      "streaming_mode_private": "progress",
      "streaming_mode_group": "off",
      "system_reminder": "You are a coordinator agent.",
      "system_reminder_private": "",
      "system_reminder_group": "You are in a PUBLIC group chat. Answer concisely, result only. Do not show commands, paths, logs, or private data.",
      "groq_api_key_file": "/path/to/shared/secrets/groq-api-key",
      "openviking_url": "http://127.0.0.1:1933",
      "openviking_key_file": "/path/to/shared/secrets/openviking.key",
      "agent_names": ["jarvis", "джарвис"],
      "topic_routing": {}
    },
    "homer": {
      "_role": "coder -- writes code, tests, deploys",
      "enabled": true,
      "telegram_bot_token": "YOUR_HOMER_BOT_TOKEN",
      "workspace": "/home/user/.claude-lab/homer/.claude",
      "model": "opus",
      "timeout_sec": 300,
      "streaming_mode": "partial",
      "system_reminder": "You are a coder agent.",
      "groq_api_key_file": "/path/to/shared/secrets/groq-api-key",
      "openviking_url": "http://127.0.0.1:1933",
      "openviking_key_file": "/path/to/shared/secrets/openviking.key",
      "agent_names": ["homer", "хомер"],
      "topic_routing": {}
    },
    "edith": {
      "_role": "inbox -- receives info, organizes knowledge",
      "enabled": true,
      "telegram_bot_token": "YOUR_EDITH_BOT_TOKEN",
      "workspace": "/home/user/.claude-lab/edith/.claude",
      "model": "sonnet",
      "timeout_sec": 120,
      "streaming_mode": "partial",
      "system_reminder": "You are a knowledge management agent.",
      "groq_api_key_file": "/path/to/shared/secrets/groq-api-key",
      "openviking_url": "http://127.0.0.1:1933",
      "openviking_key_file": "/path/to/shared/secrets/openviking.key",
      "agent_names": ["edith", "эдит"],
      "topic_routing": {}
    }
  }
}
