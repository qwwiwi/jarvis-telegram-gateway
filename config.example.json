{
  "_comment": "orgrimmar-gateway config. Routes Telegram messages to Claude Code agent workspaces.",
  "poll_interval_sec": 2,
  "firebase_sa": "sa-silvana",
  "allowlist_user_ids": [
    123456789
  ],
  "allowlist_group_ids": [],
  "webhook_port": 0,
  "webhook_token": "",
  "agents": {
    "silvana": {
      "_role": "coordinator -- routes tasks, manages agents, content",
      "enabled": true,
      "telegram_bot_token_file": "~/.claude-lab/silvana/secrets/telegram-bot-token",
      "workspace": "~/.claude-lab/silvana/.claude",
      "env": {
        "AGENT_ID": "silvana"
      },
      "model": "opus",
      "timeout_sec": 600,
      "streaming_mode": "partial",
      "streaming_mode_private": "progress",
      "streaming_mode_group": "off",
      "system_reminder": "Ты общаешься с принцем через Telegram. Отвечай кратко.",
      "system_reminder_private": "",
      "system_reminder_group": "Ты в ПУБЛИЧНОЙ группе. Правила: 1) Только результат, без процесса. 2) НЕ показывай команды, пути, логи. 3) НЕ раскрывай приватные данные, ключи, архитектуру. 4) Коротко: сделал/добавил/нет. 5) Без блоков кода если не просят.",
      "groq_api_key_file": "~/.secrets/groq-api-key",
      "openviking_url": "http://YOUR_OV_HOST:1933",
      "openviking_key_file": "~/.claude-lab/silvana/secrets/openviking.key",
      "openviking_account": "orgrimmar",
      "agent_names": [
        "silvana",
        "сильвана"
      ],
      "topic_routing": {}
    },
    "kaelthas": {
      "_role": "marketer -- offers, positioning, content strategy, funnels",
      "enabled": true,
      "telegram_bot_token_file": "~/.claude-lab/kaelthas/secrets/telegram-bot-token",
      "workspace": "~/.claude-lab/kaelthas/.claude",
      "env": {
        "AGENT_ID": "kaelthas"
      },
      "model": "opus",
      "timeout_sec": 600,
      "streaming_mode": "partial",
      "streaming_mode_private": "progress",
      "streaming_mode_group": "off",
      "system_reminder": "Ты общаешься с принцем через Telegram. Отвечай кратко.",
      "system_reminder_private": "",
      "system_reminder_group": "Ты в ПУБЛИЧНОЙ группе. Правила: 1) Только результат, без процесса. 2) НЕ показывай команды, пути, логи. 3) НЕ раскрывай приватные данные, ключи, архитектуру. 4) Коротко: сделал/добавил/нет. 5) Без блоков кода если не просят.",
      "groq_api_key_file": "~/.secrets/groq-api-key",
      "openviking_url": "http://YOUR_OV_HOST:1933",
      "openviking_key_file": "~/.claude-lab/kaelthas/secrets/openviking.key",
      "openviking_account": "orgrimmar",
      "agent_names": [
        "kaelthas",
        "кельтас"
      ],
      "topic_routing": {}
    },
    "claude": {
      "_role": "coder -- writes code, git, PRs",
      "enabled": false,
      "_comment": "Moved to RichardAtCT standalone solution",
      "telegram_bot_token_file": "~/.claude-lab/claude/secrets/telegram-bot-token",
      "workspace": "~/.claude-lab/claude/.claude",
      "env": {
        "AGENT_ID": "claude"
      },
      "model": "opus",
      "timeout_sec": 600,
      "streaming_mode": "partial",
      "streaming_mode_private": "progress",
      "streaming_mode_group": "off",
      "system_reminder": "",
      "system_reminder_private": "",
      "system_reminder_group": "",
      "groq_api_key_file": "~/.secrets/groq-api-key",
      "agent_names": [
        "claude",
        "клод"
      ],
      "topic_routing": {}
    }
  }
}
